{
  "name": "@gigahierz/builder-codes",
  "version": "0.1.0-rc.1",
  "description": "ERC-8021 builder-code attribution for Celo. One-line tagging and verification on top of ox.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "ox": "^0.10.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "viem": "^2.21.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "viem": "^2"
  },
  "peerDependenciesMeta": {
    "viem": {
      "optional": true
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "celo",
    "erc-8021",
    "builder-codes",
    "attribution",
    "ox"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GigaHierz/builder-codes.git"
  }
}
